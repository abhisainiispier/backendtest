# ============================================
# DATABASE CONFIGURATION (REQUIRED)
# ============================================
# All database credentials MUST be set via environment variables
# DO NOT hardcode credentials in the application code

# Database Host (hostname or IP address)
# - For Docker: mysql (service name)
# - For Local: localhost
DB_HOST=localhost

# Database User
# - For Docker: appuser
# - For Local: root
DB_USER=root

# Database Password
# - Make this strong in production!
DB_PASSWORD=password

# Database Name
# The database to connect to
DB_NAME=fullstack_db

# Database Port
# Standard MySQL port
DB_PORT=3306

# ============================================
# SERVER CONFIGURATION (REQUIRED)
# ============================================

# API Port (port where Express server listens)
API_PORT=5000

# Node Environment
# - development: for local development
# - production: for Docker/production
NODE_ENV=development

# ============================================
# IMPORTANT NOTES
# ============================================
# 1. All variables above are REQUIRED
# 2. Copy this file to .env and fill in actual values
# 3. Never commit .env file to version control
# 4. Use strong passwords in production
# 5. For Docker, use .env.docker instead
